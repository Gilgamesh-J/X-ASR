<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================== palette (macOS DesignTokens, dark-first) ===================== -->
    <SolidColorBrush x:Key="Text"        Color="#ECECF1"/>
    <SolidColorBrush x:Key="TextMuted"   Color="#8A8A99"/>
    <SolidColorBrush x:Key="Surface"     Color="#15151B"/>
    <SolidColorBrush x:Key="Surface2"    Color="#1E1E26"/>
    <SolidColorBrush x:Key="Field"       Color="#16161C"/>
    <SolidColorBrush x:Key="Hairline"    Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="HairlineStrong" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="AccentA"     Color="#7C5CFF"/>
    <SolidColorBrush x:Key="AccentB"     Color="#38E1D6"/>
    <SolidColorBrush x:Key="AccentSoft"  Color="#337C5CFF"/>
    <SolidColorBrush x:Key="Hover"       Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="Success"     Color="#45D483"/>
    <SolidColorBrush x:Key="Warn"        Color="#FFB020"/>
    <SolidColorBrush x:Key="Danger"      Color="#FF5C66"/>
    <LinearGradientBrush x:Key="AccentGrad" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C5CFF" Offset="0"/>
        <GradientStop Color="#38E1D6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Sidebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1A22" Offset="0"/>
        <GradientStop Color="#141419" Offset="1"/>
    </LinearGradientBrush>

    <!-- ===================== text styles ===================== -->
    <Style x:Key="GroupTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="6,18,0,8"/>
    </Style>
    <Style x:Key="RowTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="RowDesc" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,3,0,0"/>
    </Style>

    <!-- ===================== card ===================== -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface2}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="26" ShadowDepth="4" Opacity="0.30" Color="#000000" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="Inset" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Field}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ===================== nav item (pill) ===================== -->
    <Style x:Key="NavItem" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Margin" Value="10,1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="GroupName" Value="nav"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" CornerRadius="10" Background="Transparent" Padding="14,0">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Hover}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== toggle ===================== -->
    <Style x:Key="Toggle" TargetType="ToggleButton">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" CornerRadius="14" Background="#2EFFFFFF">
                        <Border x:Name="thumb" Width="22" Height="22" CornerRadius="11" Background="White"
                                HorizontalAlignment="Left" Margin="3,0,0,0">
                            <Border.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.35" Color="#000000"/></Border.Effect>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource AccentGrad}"/>
                            <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== ghost / solid buttons ===================== -->
    <Style x:Key="Ghost" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="9" Background="{StaticResource Field}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Hover}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource HairlineStrong}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="Solid" TargetType="Button" BasedOn="{StaticResource Ghost}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="9" Background="{StaticResource AccentGrad}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.9"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== themed textbox ===================== -->
    <Style x:Key="FieldBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentB}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{StaticResource Field}" CornerRadius="10" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="12,9">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== combobox (select) ===================== -->
    <Style x:Key="Chev" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value><ControlTemplate TargetType="ToggleButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="Select" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Style="{StaticResource Chev}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <Border Background="{StaticResource Field}" CornerRadius="10" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="12,0" IsHitTestVisible="False">
                            <Grid>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="9"
                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                            <Border Background="#1E1E26" CornerRadius="10" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Margin="0,4,0,0" Padding="4"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#000000"/></Border.Effect>
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SelectItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bd" CornerRadius="7" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="bd" Property="Background" Value="{StaticResource Hover}"/></Trigger>
                        <Trigger Property="IsSelected" Value="True"><Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== thin macOS-style scrollbar ===================== -->
    <Style x:Key="SbThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="3.5" Background="#4DFFFFFF" Width="7" HorizontalAlignment="Center"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="11"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb><Thumb Style="{StaticResource SbThumb}"/></Track.Thumb>
                            <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/></Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/></Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- badge -->
    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
        <Setter Property="Padding" Value="7,1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>
